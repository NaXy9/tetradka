# ---------------------------------------------------------------------------
# Tetradka — environment template. Copy to `.env` and fill in.
# All service addresses come from env only (no localhost hardcoded in code).
# Hostnames below (postgres, redis, minio, livekit) are Docker Compose service names.
# ---------------------------------------------------------------------------

# --- Docker Compose profiles to start; dev runs the full stack at once ---
COMPOSE_PROFILES=app,video,worker

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Used by `make bootstrap` (createsuperuser --noinput)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

# --- Database (PostgreSQL 16) ---
DATABASE_URL=postgres://tetradka:tetradka@postgres:5432/tetradka

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- LiveKit (video, added in Stage 2) ---
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret_change_me_at_least_32_chars

# --- S3 / MinIO (recordings; media never touches local disk) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_BUCKET_RECORDINGS=tetradka-recordings

# --- External providers: abstracted, default to mock for dev/tests ---
TRANSCRIPTION_PROVIDER=mock          # mock | openai | groq
SUMMARY_PROVIDER=mock                # mock | openai | anthropic
PAYMENT_PROVIDER=mock                # mock | yookassa

OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# --- YooKassa (payments, Stage 4) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# --- AI pipeline (Stage 3) ---
# Real summary prompts are the "secret sauce" and live outside the repo.
# Point this at a private file in prod; the repo ships only a stub example.
SUMMARY_PROMPT_PATH=prompts/summary.example.txt
FREE_TIER_TRANSCRIPTION_MINUTES=120

# --- Recordings retention (Stage 3) ---
RECORDING_RETENTION_DAYS=30
