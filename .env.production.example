# ---------------------------------------------------------------------------
# Tetradka — production environment template. Copy to `.env.production` on the
# server, fill in, and run: docker compose --env-file .env.production up -d
# `.env.production` itself is gitignored — real values never enter the repo.
# ---------------------------------------------------------------------------

# Compose profiles THIS machine runs. Stage 0: one VPS runs everything.
# Later stages: the video machine runs only `video`, the processing machine
# only `worker`, and the API machine only `app`.
COMPOSE_PROFILES=app,video,worker

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_SECRET_KEY=            # 50+ random chars: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=api.tetradka.app

# --- Database (PostgreSQL 16) ---
POSTGRES_PASSWORD=            # strong password; duplicate it inside DATABASE_URL
DATABASE_URL=postgres://tetradka:CHANGE_ME@postgres:5432/tetradka

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_QUEUES=default,media,gpu

# --- LiveKit: when video moves to its own machine, only this URL changes ---
LIVEKIT_URL=wss://video.tetradka.app
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=           # 32+ chars: openssl rand -hex 32

# --- S3: managed S3 in production (Hetzner / B2 / Yandex), not MinIO ---
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=
S3_BUCKET_RECORDINGS=tetradka-recordings

# --- External providers ---
TRANSCRIPTION_PROVIDER=groq
SUMMARY_PROVIDER=anthropic
PAYMENT_PROVIDER=yookassa

OPENAI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=

YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Shared secret for payment webhook signature verification (inject a strong value).
PAYMENT_WEBHOOK_SECRET=

# --- AI pipeline: the real prompt file lives outside the repo ---
SUMMARY_PROMPT_PATH=/etc/tetradka/prompts/summary.txt
FREE_TIER_TRANSCRIPTION_MINUTES=120
RECORDING_RETENTION_DAYS=30
